    },
    onFirstConsent: () => {
        logConsent();
    },

    onChange: () => {
        logConsent();
    },
    guiOptions: {
        consentModal: {
            layout: 'box',
            position: 'bottom left',
            flipButtons: false,
            equalWeightButtons: true
        },
        preferencesModal: {
            layout: 'box',
            // position: 'left right',
            flipButtons: false,
            equalWeightButtons: true
        }
    },
    revision: 1
