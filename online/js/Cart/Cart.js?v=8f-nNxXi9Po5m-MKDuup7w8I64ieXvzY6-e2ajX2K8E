    function CheckUserMember() {
        var GetFormData = BASEURL + "/Cart/CheckWebCustomer";
        var ajaxSettings = {
            type: "GET",
            url: GetFormData,
            async: false,
            success: function (data) {
                switch (data) {
                    case 0:
                        CreateOrderNow();
                        break;
                    case 1:
                        CheckPartUrGent();
                        break;
                }
            }
        };
        $.get(ajaxSettings);
    }
    Cart.CheckUserMember = CheckUserMember;
    function CheckPartUrGent() {
        SccLoadingModal.Show();
        $("#newPartList").val(null);
        CartItemListGrid = FormHelper.GetGridById("CartItemListGrid");
        var NewjsonData = JSON.stringify(CartItemListGrid.dataSource);
        $("#newPartList").val(NewjsonData);
        var jsonData = JSON.stringify(CartItemListGrid.dataSource);
        $("#CartDetail").val(jsonData);
        $.ajax({
            type: "POST",
            url: BASEURL + "/Cart/CheckCartBeforeOrder",
            data: $("#formCartItem").serialize(),
            success: function (data) {
                CartItem.updateCartItemListGridDatasource(data.CartDetail);
                HighlightParts();
                HighlightPartsColor();
                Layout.LoadNewAlert();
                switch (data.InfoStatus) {
                    case 1:
                        SccLoadingModal.Hide(CreateOrderNow);
                        break;
                    case 10:
                        SccLoadingModal.Hide(CartItem.ShowPartConfirmUrgentModal);
                        break;
                }
            }
        });
    }
