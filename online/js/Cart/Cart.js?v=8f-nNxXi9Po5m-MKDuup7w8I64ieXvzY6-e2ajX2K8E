    function newInsertPart(PssProductId, PssBrandId, PssModelId, PartNo, AddQty, PictureId, PageNo) {
        $("#newPartList").val(null);
        $("#CartDetail").val(null);
        var newPartList = [];
        var partInfo = {
            PSS_PRODUCT_ID: PssProductId,
            PSS_BRAND_ID: PssBrandId,
            PSS_MODEL_ID: PssModelId,
            PART_NO: PartNo,
            TOTAL_QTY: AddQty,
            PICTURE_ID: PictureId,
            PAGE_NO: PageNo
        };
        newPartList.push(partInfo);
        var NewjsonData = JSON.stringify(newPartList);
        $("#newPartList").val(NewjsonData);
        CartItemListGrid = FormHelper.GetGridById("CartItemListGrid");
        var jsonData = JSON.stringify(CartItemListGrid.dataSource);
        $("#CartDetail").val(jsonData);
        $.ajax({
            type: "POST",
            url: BASEURL + "/Cart/NewInsertParts",
            data: $("#formCartItem").serialize(),
            success: function (data) {
                CartItem.updateCartItemListGridDatasource(data.CartDetail);
                switch (data.InfoStatus) {
                    case 1:
                        CartItem.ShowAddCartSuccessModal();
                        break;
                    case 8:
                        CartItem.ShowPartDiscontinuedModal(data.InfoMessageCart);
                        break;
                    case 9:
                        CartItem.ShowNotReadyPartModal();
                        break;
                }
                Layout.LoadNewAlert();
            }
        });
    }
    Cart.newInsertPart = newInsertPart;
