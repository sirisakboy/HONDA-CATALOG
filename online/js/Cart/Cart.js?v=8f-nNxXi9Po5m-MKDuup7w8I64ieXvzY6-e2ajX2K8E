        $.ajax({
            type: "POST",
            url: url,
            success: function (data) {
                //Part Discontinued
                if (data.status == 1) {
                    if (data.result.length == 1) {
                        $('#confirm-Discontinued').modal('show');
                        confirmDiscontinuedDialog(function (confirm) {
                            $('#confirm-Discontinued').modal('hide');
                            if (confirm) {
                                var RepProductId = data.result[0].PRODUCT_ID;
                                var RepBrandId = data.result[0].BRAND_ID;
                                var RepPartNo = data.result[0].PART_NO;
                                var RepQtyUse = data.result[0].QTY_USE;
                                newInsertPart(RepProductId, RepBrandId, "", RepPartNo, RepQtyUse, "0", "0");
                            }
                        });
                    }
                    else {
                        CartItem.ShowPartDiscontinuedModal(data.InfoMessage);
                    }
                }
                //Out of Stock
                if (data.status == 2) {
                    if (data.result.length == 1) {
                        $('#confirm-OutStock').modal('show');
                        confirmOutStockDialog(function (confirm) {
                            $('#confirm-OutStock').modal('hide');
                            if (confirm) {
                                var RepProductId = data.result[0].PRODUCT_ID;
                                var RepBrandId = data.result[0].BRAND_ID;
                                var RepPartNo = data.result[0].PART_NO;
                                var RepQtyUse = data.result[0].QTY_USE;
                                newInsertPart(RepProductId, RepBrandId, "", RepPartNo, RepQtyUse, "0", "0");
                            }
                            else {
                                newInsertPart(PssProductId, PssBrandId, PssModelId, PartNo, AddQty, PictureId, PageNo);
                            }
                        });
                    }
                    else {
                        newInsertPart(PssProductId, PssBrandId, PssModelId, PartNo, AddQty, PictureId, PageNo);
                    }
                }
                //UnChanged
                if (data.status == 0) {
                    newInsertPart(PssProductId, PssBrandId, PssModelId, PartNo, AddQty, PictureId, PageNo);
                }
            }
        });
    }
