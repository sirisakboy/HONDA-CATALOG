$(function () {
    FormHelper.Init();
    $("#PROVINCE_ID").on("change", Register.ChangeProvinceAddress);
    $("#AMPHUR_ID").on("change", Register.ChangeAmphurAddress);
    FormHelper.InputNumber("CARD_ID");
    FormHelper.InputNumber("ZIPE_CODE");
    FormHelper.InputNumber("MOBILE_NO");
    FormHelper.InputNumber("TEL_NO");
    SccLoadingModal.Init("LoadingModal");
    $("#BtnSubmitRegister").on("click", Register.SubmitRegister);
});
var Register;
(function (Register) {
    function SubmitRegister() {
        SccLoadingModal.Show();
        if ($("#FormRegister").valid()) {
            FormHelper.Get_ButtonElementById("BtnSubmitRegister").disabled = true;
            $("#FormRegister").trigger("submit");
        }
        else {
            SccLoadingModal.Hide();
            FormHelper.Get_ButtonElementById("BtnSubmitRegister").disabled = false;
        }
        var captchaToken = $("#CaptchaToken").val();
        if (captchaToken) {
            $("#FormRegister").trigger("submit");
