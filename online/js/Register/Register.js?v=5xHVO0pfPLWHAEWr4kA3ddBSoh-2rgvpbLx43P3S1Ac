    function RefreshAmphurList(RefProviceId, RrefAmphurId, RefZipCodeId) {
        //parameter1 Provice
        //parameter1 Amphur
        //parameter2 ZipCode
        var path = BASEURL + "/Register/GetAmphurList?provinceID=" + $("#" + RefProviceId).val();
