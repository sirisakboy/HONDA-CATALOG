$(function () {
    FormHelper.Init();
    $("#BrandId").on("change", HomePage.RefreshWebModelList);
    HomePage.Init();
    SccLoadingModal.Init("LoadingModal");
    $("#CateBrandId").on("change", HomePage.RefreshCateWebModelList);
    $("#CateModelId").on("change", HomePage.ChangeCateModelPromotion);
});
var HomePage;
(function (HomePage) {
    function RefreshWebModelList() {
        var path = BASEURL + "/Home/GetWebModelList?BrandId=" + $("#BrandId").val();
        $.ajax({
            url: path,
            type: "GET",
            success: function (data) {
                $("#ModelId").empty();
                $.each(data, function (index, item) {
                    $("#ModelId").append(new Option(item.Text, item.Value));
                });
            },
            contentType: "application/json",
            dataType: 'json'
        });
    }
    HomePage.RefreshWebModelList = RefreshWebModelList;
