    function HomeInsertPart(e) {
        var PssProductId = e.dataset.pssproductid;
        var PssBrandId = e.dataset.pssbrandid;
        var PartNo = e.dataset.partno;
        var Price = e.dataset.price;
        var Price5 = e.dataset.price5;
        $.ajax({
            url: BASEURL + "/Cart/InsertParts",
            contentType: 'application/json; charset=utf-8',
            dataType: 'json',
            type: "GET",
            data: {
                PssProductId: PssProductId,
                PssBrandId: PssBrandId,
                PartNo: PartNo,
                AddQty: 1,
                Price: Price,
                Price5: Price5
            }
        })
            .done(function (data) {
            switch (data.InfoStatus) {
                case 1:
                    ShowAddCartSuccessModal();
                    break;
                case 8:
                    ShowPartDiscontinuedModal();
                    break;
            }
            Layout.LoadNewAlert();
        });
    }
    HomePage.HomeInsertPart = HomeInsertPart;
    function HomeBuyNow(e) {
        var PssProductId = e.dataset.pssproductid;
        var PssBrandId = e.dataset.pssbrandid;
        var PartNo = e.dataset.partno;
        var Price = e.dataset.price;
        var Price5 = e.dataset.price5;
        $.ajax({
            url: BASEURL + "/Cart/InsertParts",
            contentType: 'application/json; charset=utf-8',
            dataType: 'json',
            type: "GET",
            data: {
                PssProductId: PssProductId,
                PssBrandId: PssBrandId,
                PartNo: PartNo,
                AddQty: 1,
                Price: Price,
                Price5: Price5
            }
        })
            .done(function (data) {
            switch (data.InfoStatus) {
                case 1:
                    window.location.href = BASEURL + "/Cart/CartView?PartNo=" + PartNo;
